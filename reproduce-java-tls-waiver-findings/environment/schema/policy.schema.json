{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mariner.internal/schema/policy.schema.json",
  "title": "Mariner transport-security policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_date",
    "rotation_window_days",
    "allowed_tls_versions",
    "mtls_required_environments"
  ],
  "properties": {
    "review_date": {
      "type": "string",
      "format": "date"
    },
    "rotation_window_days": {
      "type": "integer",
      "minimum": 0
    },
    "allowed_tls_versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "TLS1.0",
          "TLS1.1",
          "TLS1.2",
          "TLS1.3"
        ]
      }
    },
    "mtls_required_environments": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "prod",
          "staging",
          "dev"
        ]
      }
    }
  }
}
