{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mariner.internal/schema/crypto.schema.json",
  "title": "Mariner key-strength and issuer-trust policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trusted_issuers",
    "keys"
  ],
  "properties": {
    "trusted_issuers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "keys": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_rsa_bits",
        "min_ec_bits"
      ],
      "properties": {
        "min_rsa_bits": {
          "type": "integer",
          "minimum": 1
        },
        "min_ec_bits": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
