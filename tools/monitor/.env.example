# Copy to tools/monitor/.env and fill in before enabling the scheduler.
# Get your key: https://cursor.com/dashboard/integrations

CURSOR_API_KEY=crsr_8b828d6cfc1eacf97797bf3315b730d92905c3a7644a0571319baf3e9affc2df

# Notifications
NOTIFY_MACOS=1

# Phone option A — iMessage yourself (same Apple ID / iCloud as this Mac)
# Use the phone number or Apple ID email that receives iMessage on your iPhone.
NOTIFY_IMESSAGE=1
IMESSAGE_TO=+12244667444

# Phone option B — ntfy push (often more reliable for background launchd jobs)
# Install "ntfy" from the App Store, subscribe to the same topic string.
NOTIFY_NTFY=1
NTFY_TOPIC=snorkel-fabrice-secret-topic-12345

# Phone option C — Slack mobile app
# NOTIFY_SLACK=1
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Optional overrides (defaults are fine for this machine)
# REPO_ROOT=/Users/fabrice-mac-mini/Documents/snorkel-ai
# STB_BIN=/Users/fabrice-mac-mini/.local/share/uv/tools/snorkelai-stb/bin/stb
# HARBOR_BIN=/Users/fabrice-mac-mini/.local/share/uv/tools/snorkelai-stb/bin/harbor
# MONITOR_MODEL=composer-2.5
# MAX_FIXES_PER_RUN=8
# MAX_ATTEMPTS_PER_FEEDBACK=2
# FIX_COOLDOWN_SEC=3600
# IMESSAGE_POLL_SEC=20
