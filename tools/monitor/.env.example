# Snorkel submission monitor — local only (gitignored)

CURSOR_API_KEY=cursor_your_api_key_here

# Cloud agent (default) — no macOS popup, no Cursor.app required
MONITOR_AGENT_RUNTIME=cloud
GITHUB_REPO_URL=https://github.com/your-user/your-repo
GITHUB_BRANCH=main
GITHUB_TOKEN=ghp_your_github_pat_here
CLOUD_WORK_ON_BRANCH=1
# Must be 0 when CLOUD_WORK_ON_BRANCH=1 — commit SHA triggers validation_error.
CLOUD_USE_COMMIT_SHA=0
CLOUD_AGENT_RETRIES=3
CLOUD_AGENT_RETRY_SEC=45

# Telegram (@nf_terminus_bot)
NOTIFY_TELEGRAM=1
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_CMD_ENABLE=1
# TELEGRAM_ALLOWED_USER_IDS=your-telegram-user-id

NOTIFY_MACOS=0

# Cloud agents run on schedule without macOS privacy prompts (no Cursor.app needed).
AUTO_AGENT_FIX=1
REQUIRE_CURSOR_OPEN=0
AUTO_GIT_COMMIT=1
ORACLE_PRECHECK=1
ORACLE_PRECHECK_TIMEOUT_SEC=900

# Notifications
NOTIFY_DIGEST=1
NOTIFY_PRIORITY_ONLY=0
NOTIFY_ON_IDLE=0
NOTIFY_QUIET_HOURS=0
NOTIFY_QUIET_START_HOUR=23
NOTIFY_QUIET_END_HOUR=7
MONITOR_TZ=America/Chicago
NOTIFY_DAILY_SUMMARY_HOUR_UTC=23

# Cost guards
MAX_FIXES_PER_RUN=1
MAX_FIXES_PER_FORCE_RUN=7
MAX_FIXES_PER_DAY=8
MAX_AGENT_MINUTES_PER_DAY=180
MAX_ATTEMPTS_PER_FEEDBACK=4
FIX_COOLDOWN_SEC=3600
DEFAULT_PAUSE=6h

MONITOR_MODEL=composer-2.5
# Cursor Composer only (cursor_sdk). Must start with composer- (e.g. composer-2.5-fast).
# MONITOR_MODEL is a deprecated alias for CURSOR_COMPOSER_MODEL.
# CURSOR_COMPOSER_MODEL=composer-2.5
COMMAND_POLL_SEC=20
GIT_WARN_MIN_FOLDERS=3

# Optional ntfy fallback
# NOTIFY_NTFY=1
# NTFY_TOPIC=your-secret-topic

# Optional overrides
# REPO_ROOT=/Users/fabrice-mac-mini/Documents/snorkel-ai
# STB_BIN=/Users/fabrice-mac-mini/.local/share/uv/tools/snorkelai-stb/bin/stb
# HARBOR_BIN=/Users/fabrice-mac-mini/.local/share/uv/tools/snorkelai-stb/bin/harbor
